# ── ONLY 2 SERVICES NEEDED — both completely free, no card ──

# 1. GEMINI API — aistudio.google.com → Get API Key → free, no card
GEMINI_API_KEY=your_gemini_api_key_here

# 2. SUPABASE — supabase.com → sign up with GitHub → New Project
#    Settings → Database → copy these values
SUPABASE_HOST=your_supabase_host_here
SUPABASE_PORT=5432
SUPABASE_DBNAME=postgres
SUPABASE_USER=postgres
SUPABASE_PASSWORD=your_supabase_password_here

# Maps: uses OpenStreetMap Nominatim — free, no key needed
# Dashboard: built into the app — no Looker needed
